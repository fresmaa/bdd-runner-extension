{
  "name": "bdd-scenario-runner-extension",
  "displayName": "Playwright BDD Runner",
  "description": "VS Code extension to run Playwright BDD scenarios directly from Gherkin .feature files.",
  "version": "1.0.1",
  "publisher": "fresma-labs",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/fresmaa/bdd-runner-extension.git"
  },
  "private": true,
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Testing"
  ],
  "keywords": [
    "playwright",
    "bdd",
    "gherkin",
    "feature",
    "qa",
    "cucumber",
    "test-runner"
  ],
  "activationEvents": [
    "onLanguage:feature"
  ],
  "main": "./out/extension.js",
  "icon": "docs/images/extension-icon.png",
  "contributes": {
    "commands": [
      {
        "command": "bddScenarioRunner.runScenarioTag",
        "title": "Run Scenario",
        "category": "Playwright BDD Runner",
        "icon": {
          "light": "docs/images/icon-run.png",
          "dark": "docs/images/icon-run.png"
        }
      },
      {
        "command": "bddScenarioRunner.runAtCursor",
        "title": "Run at Cursor",
        "category": "Playwright BDD Runner",
        "icon": {
          "light": "docs/images/icon-run.png",
          "dark": "docs/images/icon-run.png"
        }
      },
      {
        "command": "bddScenarioRunner.runScenarioTagAtLine",
        "title": "Run Scenario at Line",
        "category": "Playwright BDD Runner"
      },
      {
        "command": "bddScenarioRunner.runCurrentFeature",
        "title": "Run Feature",
        "category": "Playwright BDD Runner",
        "icon": {
          "light": "docs/images/icon-feature.png",
          "dark": "docs/images/icon-feature.png"
        }
      },
      {
        "command": "bddScenarioRunner.rerunFailed",
        "title": "Re-run Failed",
        "category": "Playwright BDD Runner",
        "icon": {
          "light": "docs/images/icon-rerun.png",
          "dark": "docs/images/icon-rerun.png"
        }
      },
      {
        "command": "bddScenarioRunner.diagnoseEnvironment",
        "title": "Diagnose Environment",
        "category": "Playwright BDD Runner"
      },
      {
        "command": "bddScenarioRunner.stopRunning",
        "title": "Stop",
        "category": "Playwright BDD Runner",
        "icon": {
          "light": "docs/images/icon-stop-light.png",
          "dark": "docs/images/icon-stop-dark.png"
        }
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "bddScenarioRunner.runScenarioTag",
          "when": "resourceExtname == .feature",
          "group": "navigation@20"
        },
        {
          "command": "bddScenarioRunner.runAtCursor",
          "when": "resourceExtname == .feature",
          "group": "navigation@20"
        },
        {
          "command": "bddScenarioRunner.runCurrentFeature",
          "when": "resourceExtname == .feature",
          "group": "navigation@21"
        },
        {
          "command": "bddScenarioRunner.rerunFailed",
          "group": "navigation@22"
        },
        {
          "command": "bddScenarioRunner.stopRunning",
          "when": "resourceExtname == .feature",
          "group": "navigation@19"
        }
      ],
      "commandPalette": [
        {
          "command": "bddScenarioRunner.runScenarioTag",
          "when": "resourceExtname == .feature"
        },
        {
          "command": "bddScenarioRunner.runAtCursor",
          "when": "resourceExtname == .feature"
        },
        {
          "command": "bddScenarioRunner.runCurrentFeature",
          "when": "resourceExtname == .feature"
        },
        {
          "command": "bddScenarioRunner.rerunFailed"
        },
        {
          "command": "bddScenarioRunner.diagnoseEnvironment"
        },
        {
          "command": "bddScenarioRunner.stopRunning"
        }
      ]
    },
    "configuration": {
      "title": "Playwright BDD Runner",
      "properties": {
        "bddScenarioRunner.packageManager": {
          "type": "string",
          "enum": [
            "auto",
            "npm",
            "yarn",
            "pnpm",
            "bun"
          ],
          "default": "auto",
          "description": "Package manager to use for running commands. 'auto' detects from packageManager field in package.json or lockfiles."
        },
        "bddScenarioRunner.commandTemplate": {
          "type": "string",
          "default": "{pm} bddgen && {pm} playwright test --grep {scenarioQuoted}{headedFlag}",
          "description": "Scenario run template. Placeholders: {pm}, {scenario}, {scenarioQuoted}, {featurePath}, {featurePathQuoted}, {runMode}, {headedFlag}."
        },
        "bddScenarioRunner.featureCommandTemplate": {
          "type": "string",
          "default": "{pm} bddgen && {pm} playwright test --grep {featureNameQuoted}{headedFlag}",
          "description": "Feature run template. Placeholders: {pm}, {featureName}, {featureNameQuoted}, {featurePath}, {featurePathQuoted}, {runMode}, {headedFlag}."
        },
        "bddScenarioRunner.exampleCommandTemplate": {
          "type": "string",
          "default": "{pm} bddgen && {pm} playwright test --grep {scenarioExampleRegexQuoted}{headedFlag}",
          "description": "Example row run template. Placeholders: {pm}, {scenario}, {scenarioQuoted}, {example}, {exampleQuoted}, {scenarioExampleRegex}, {scenarioExampleRegexQuoted}, {featurePath}, {featurePathQuoted}, {runMode}, {headedFlag}."
        },
        "bddScenarioRunner.rerunFailedCommandTemplate": {
          "type": "string",
          "default": "{pm} bddgen && {pm} playwright test --last-failed{headedFlag}",
          "description": "Re-run failed template. Placeholders: {pm}, {runMode}, {headedFlag}."
        },
        "bddScenarioRunner.terminalName": {
          "type": "string",
          "default": "Playwright BDD Runner",
          "description": "Terminal name used to run BDD scenarios."
        },
        "bddScenarioRunner.autoClearTerminal": {
          "type": "boolean",
          "default": true,
          "description": "Clear terminal before running a new scenario command."
        },
        "bddScenarioRunner.showTerminalOnRun": {
          "type": "boolean",
          "default": false,
          "description": "Automatically reveal terminal when starting a run."
        },
        "bddScenarioRunner.askRunMode": {
          "type": "boolean",
          "default": true,
          "description": "Ask whether to run in headless or headed mode each time."
        },
        "bddScenarioRunner.defaultRunMode": {
          "type": "string",
          "enum": [
            "headless",
            "headed"
          ],
          "default": "headless",
          "description": "Default run mode when askRunMode is disabled."
        },
        "bddScenarioRunner.forceShell": {
          "type": "string",
          "enum": [
            "auto",
            "git-bash",
            "pwsh",
            "powershell",
            "cmd",
            "bash"
          ],
          "default": "auto",
          "description": "Force execution shell. auto = resolve based on OS/profile with safe fallbacks."
        },
        "bddScenarioRunner.gitBashPath": {
          "type": "string",
          "default": "",
          "description": "Optional absolute path to Git Bash executable (Windows), for example C:/Program Files/Git/bin/bash.exe."
        },
        "bddScenarioRunner.pwshPath": {
          "type": "string",
          "default": "pwsh",
          "description": "pwsh executable path or command name when forceShell is pwsh."
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p .",
    "test": "npm run compile && node --test \"out/**/*.test.js\"",
    "watch": "tsc -watch -p .",
    "package": "vsce package --allow-missing-repository",
    "publish": "vsce publish --allow-missing-repository",
    "publish:patch": "vsce publish patch --allow-missing-repository",
    "publish:minor": "vsce publish minor --allow-missing-repository",
    "publish:major": "vsce publish major --allow-missing-repository"
  },
  "devDependencies": {
    "@types/node": "^22.14.1",
    "@types/vscode": "^1.90.0",
    "@vscode/vsce": "^3.6.2",
    "typescript": "^5.8.3"
  }
}
